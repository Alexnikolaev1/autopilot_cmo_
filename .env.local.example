# Получить ключ: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Первая модель в цепочке (по умолчанию в приложении: gemini-2.5-flash-lite).
# GEMINI_MODEL=gemini-2.5-flash-lite

# Полностью переопределить порядок моделей при 429/квоте (через запятую):
# GEMINI_MODEL_FALLBACKS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash

# Секрет для шифрования сессии (любая случайная строка ≥32 символов)
SESSION_SECRET=change_this_to_a_random_32_char_string

# Одноклассники — секретный ключ приложения (НЕ публичный application_key)
# Найдите в настройках вашего приложения на ok.ru/devaccess
OK_SECRET_KEY=your_ok_secret_key_here

# --- Upstash Redis (рекомендуется для прод на Vercel) ---
# Marketplace → Redis → Connect to Project. Обычно:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Или при обычной Redis-интеграции может быть только:
# REDIS_URL=
# У старых проектов миграции с Vercel KV могут остаться KV_REST_API_URL / KV_REST_API_TOKEN.
# Без Redis rate limit, idempotency и счётчики метрик — в памяти одного воркера.
